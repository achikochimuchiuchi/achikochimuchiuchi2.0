rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: scandals
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required) - Scandal title
    //   - date: string (required) - Date of news
    //   - category: string (required, enum: ["Administrative", "Personal"])
    //   - description: string (required) - Summary
    //   - sourceUrl: string (required, format: uri)
    //   - location: string (optional)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidScandal(data) {
      return data.keys().hasAll(['title', 'date', 'category', 'description', 'sourceUrl', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 500 &&
             data.date is string &&
             data.category in ['Administrative', 'Personal'] &&
             data.description is string && data.description.size() < 5000 &&
             data.sourceUrl is string &&
             data.createdAt is timestamp;
    }

    function isValidArchiveItem(data) {
      return data.keys().hasAll(['title', 'date', 'category', 'description', 'intensity', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.date is string &&
             data.category is string &&
             data.description is string && data.description.size() < 2000 &&
             data.intensity is number && data.intensity >= 0 && data.intensity <= 1 &&
             data.createdAt is timestamp;
    }

    match /scandals/{scandalId} {
      allow read: if true;
      // In a real app, we'd restrict this to an admin or a specific service account.
      // For this demo, we allow creation if it's a valid scandal.
      allow create: if isValidScandal(request.resource.data);
      allow update, delete: if false;
    }

    match /archive/{archiveId} {
      allow read: if true;
      allow create: if isValidArchiveItem(request.resource.data);
      allow update, delete: if false;
    }
  }
}
